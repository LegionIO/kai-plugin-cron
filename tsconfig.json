{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "lib": ["ES2022"],
    "outDir": ".",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": false,
    "sourceMap": false,
    "jsx": "react",
    "jsxFactory": "h",
    "allowImportingTsExtensions": false
  },
  "include": ["main.ts", "src/**/*.ts", "src/**/*.tsx"],
  "exclude": ["node_modules"]
}
